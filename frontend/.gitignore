node_modules
dist-ssr
*.local

# dist/ is intentionally NOT ignored — Hostinger's deploy runs `npm install` but there's no
# confirmed build-step hook, so the built frontend is committed directly and served by the
# Express backend (see server.js). Run `npm run frontend:build` from the repo root and commit
# the result after any frontend change.

