# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Server ---
PORT=3000
NODE_ENV=production
APP_URL=https://gatewaysmartcrm.com

# --- MySQL (from Hostinger hPanel > Databases > MySQL Databases) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# --- Email (optional — leave blank to disable and fall back to logging only) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Address Gateway <startup@addressgateway.com>"

# --- File uploads (profile photos, KYC documents) ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
